classDiagram
    class Project {
        +String id (PK)
        +String name
        +String clientId
        +String description
        +Date startDate
        +Date deadline
        +Enum status (Draft, In Progress, Completed, On Hold)
        +Enum priority (Low, Medium, High, Critical)
        +String managerId (FK)
        +CalculationConfig calculationConfig
    }

    class CalculationConfig {
        +SlotMap slots
        +String formula
        +String resultLabel
    }

    class SlotMap {
        +String v1
        +String v2
        +String v3
        +String v4
        +String v5
        +String v6
