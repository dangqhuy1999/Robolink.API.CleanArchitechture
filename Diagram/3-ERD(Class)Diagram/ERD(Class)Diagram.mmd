        +String v9
        +String v10
    }

    class PhaseTask {
        +String id (PK)
        +String projectId (FK)
        +int phaseId (FK)
        +String description
        +String assignedStaffId (FK)
        +int processRate
        +Date dueDate
        +Enum status (Pending, In Progress, Review, Done)
        +float v1
