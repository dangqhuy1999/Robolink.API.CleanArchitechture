    class ProjectPhase {
        +int id (PK)
        +String name
    }

    class Staff {
        +String id (PK)
        +String fullName
        +Enum department (Engineering, Production, Planning, QC)
        +Enum role (Admin, Manager, Lead, Operator)
    }

    class ProductionRecord {
        +String id (PK)
        +String productCode
        +Date mfgDate
        +int quantity
        +int shift (1, 2, 3)
        +String lotNumber
        +String batchNumber
        +String machineId
        +String operatorId (FK)
        +float temperature
        +Enum status (Running, Idle, Maintenance, Error)
        +long timestamp
    }

    %% Relationships based on your code logic
