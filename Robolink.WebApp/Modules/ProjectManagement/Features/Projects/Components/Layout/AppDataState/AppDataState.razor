@if (IsLoading)
{
    @* Giao diện lúc đang Load *@
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary me-2" role="status"></div>
        <span>@LoadingMessage</span>
    </div>
}
else if (IsEmpty)
{
    @* Giao diện lúc không có data *@
    <div class="alert alert-light border border-dashed text-center p-5">
        <i class="bi bi-inbox fs-1 text-muted"></i>
        <p class="mt-2 text-secondary">@EmptyMessage</p>
        @if (OnAction.HasValue)
        {
            <button class="btn btn-primary btn-sm mt-2" @onclick="OnAction.Value">
                @ActionLabel
            </button>
        }
    </div>
}
else
{
    @* Có data thì hiện nội dung bên trong *@
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsEmpty { get; set; }
    [Parameter] public string LoadingMessage { get; set; } = "Đang nạp dữ liệu...";
    [Parameter] public string EmptyMessage { get; set; } = "Không tìm thấy dữ liệu nào.";
    [Parameter] public string ActionLabel { get; set; } = "Thêm mới ngay";
    [Parameter] public EventCallback? OnAction { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;
}