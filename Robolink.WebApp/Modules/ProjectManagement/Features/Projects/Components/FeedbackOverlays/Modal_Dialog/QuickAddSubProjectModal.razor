<div class="modal @(ShowModal ? "show d-block" : "")" tabindex="-1" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg shadow-lg">
        <div class="modal-content border-0">

            @* --- 1. HEADER: Màu sắc phân biệt loại hành động --- *@
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-diagram-3-plus me-2"></i> Quick Add Sub-Project
                </h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
            </div>

            <div class="modal-body p-4">
                @if (parentProject == null)
                {
                    <div class="alert alert-danger shadow-sm d-flex align-items-center">
                        <i class="bi bi-exclamation-octagon fs-4 me-2"></i>
                        <div>Parent project not found. Please close and try again.</div>
                    </div>
                }
                else if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-info" role="status"></div>
                        <p class="mt-2 text-muted">Preparing your form...</p>
                    </div>
                }
                else
                {
                    @* --- 2. CONTEXT BOX: Khóa ngữ cảnh Tầng 1 --- *@
                    <div class="card border-0 bg-light mb-4 shadow-sm">
                        <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between">
                            <div>
                                <small class="text-uppercase fw-bold text-muted d-block" style="font-size: 0.7rem;">Adding Sub-project to:</small>
                                <span class="text-primary fw-bold">@parentProject.ProjectCode - @parentProject.Name</span>
                            </div>
                            <i class="bi bi-layers-half text-info fs-3 opacity-50"></i>
                        </div>
                    </div>

                    <form @onsubmit="HandleCreateSubProject">

                        @* --- SECTION A: IDENTIFICATION (Mã & Tên) --- *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Sub-Project Code</label>
                                <input type="text" class="form-control border-primary-subtle" @bind="request.ProjectCode" placeholder="SUB-001" required />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Sub-Project Name</label>
                                <input type="text" class="form-control border-primary-subtle" @bind="request.Name" placeholder="Enter sub-project title..." required />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Short Description</label>
                                <textarea class="form-control" @bind="request.Description" rows="2" placeholder="Describe the scope..."></textarea>
                            </div>
                        </div>

                        @* --- SECTION B: LOGISTICS (Nhân sự & Ưu tiên) --- *@
                        <div class="row g-3 mb-4 p-3 border rounded bg-white shadow-sm">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary"><i class="bi bi-person-badge me-1"></i> Project Manager</label>
                                <InputSelect class="form-select border-info-subtle" @bind-Value="request.ManagerId">
                                    <option value="">-- Select Manager --</option>
                                    @if (managers != null)
                                    {
                                        @foreach (var staff in managers)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary"><i class="bi bi-flag me-1"></i> Priority</label>
                                <InputSelect class="form-select border-info-subtle" @bind-Value="request.Priority">
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2" selected>High</option>
                                    <option value="3">Critical</option>
                                </InputSelect>
                            </div>
                        </div>

                        @* --- SECTION C: TIMELINE & BUDGET (Thời gian & Tiền bạc) --- *@
                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 bg-light">
                                    <h6 class="fw-bold mb-3 text-muted border-bottom pb-2">Schedule</h6>
                                    <div class="mb-2">
                                        <label class="small fw-bold">Start Date</label>
                                        <InputDate class="form-control form-control-sm" @bind-Value="request.StartDate" />
                                    </div>
                                    <div>
                                        <label class="small fw-bold">Deadline</label>
                                        <InputDate class="form-control form-control-sm" @bind-Value="request.Deadline" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 bg-light">
                                    <h6 class="fw-bold mb-3 text-muted border-bottom pb-2">Budgeting</h6>
                                    <div class="mb-2">
                                        <label class="small fw-bold">Internal Budget</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">$</span>
                                            <InputNumber class="form-control text-end" @bind-Value="request.InternalBudget" />
                                        </div>
                                    </div>
                                    <div>
                                        <label class="small fw-bold">Customer Budget</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">$</span>
                                            <InputNumber class="form-control text-end" @bind-Value="request.CustomerBudget" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* --- 3. FOOTER: Chốt hạ hành động --- *@
                        <div class="modal-footer px-0 pb-0 border-0 mt-4">
                            <button type="button" class="btn btn-link text-decoration-none text-muted px-4" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-info px-5 fw-bold shadow">
                                <i class="bi bi-check2-circle me-1"></i> Create Sub-Project
                            </button>
                        </div>


                    </form>
                }
            </div>
        </div>
    </div>
</div>