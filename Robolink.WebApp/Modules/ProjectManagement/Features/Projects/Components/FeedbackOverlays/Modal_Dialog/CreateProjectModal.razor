
@if (ShowModal)
{
    <div class="modal fade show d-block" role="dialog">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                
                <!-- ===== MODAL HEADER ===== -->
                <div class="modal-header">
                    <h5 class="modal-title">@State.ModalTitle</h5>
                    <button type="button" 
                            class="btn-close" 
                            @onclick="HandleCloseAsync" 
                            disabled="@State.IsProcessing">
                    </button>
                </div>

                <!-- ===== MODAL BODY ===== -->
                <div class="modal-body">
                    @if (State.IsLoadingData)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2 text-muted">Loading data...</p>
                        </div>
                    }
                    else
                    {
                        <!-- General Error Message -->
                        @if (!string.IsNullOrEmpty(State.LastErrorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-circle"></i> @State.LastErrorMessage
                                <button type="button" class="btn-close" @onclick="@(() => State.LastErrorMessage = null)"></button>
                            </div>
                        }

                        <form>
                            <!-- Project Name -->
                            <div class="mb-3">
                                <label for="projectName" class="form-label">
                                    Project Name <span class="text-danger">*</span>
                                </label>
                                <input type="text" 
                                       class="form-control @(HasFieldError(nameof(State.FormData.Name)) ? "is-invalid" : "")" 
                                       id="projectName"
                                       @bind="State.FormData.Name"
                                       @onchange="e => HandleFieldChanged(nameof(State.FormData.Name), e.Value)"
                                       placeholder="Enter project name"
                                       disabled="@State.IsSubmitting" />
                                @if (HasFieldError(nameof(State.FormData.Name)))
                                {
                                    <div class="invalid-feedback d-block">
                                        @GetFieldError(nameof(State.FormData.Name))
                                    </div>
                                }
                            </div>

                            <!-- Description -->
                            <div class="mb-3">
                                <label for="projectDescription" class="form-label">Description</label>
                                <textarea class="form-control @(HasFieldError(nameof(State.FormData.Description)) ? "is-invalid" : "")" 
                                          id="projectDescription" 
                                          rows="3"
                                          @bind="State.FormData.Description"
                                          @onchange="e => HandleFieldChanged(nameof(State.FormData.Description), e.Value)"
                                          placeholder="Enter project description"
                                          disabled="@State.IsSubmitting"></textarea>
                                @if (HasFieldError(nameof(State.FormData.Description)))
                                {
                                    <div class="invalid-feedback d-block">
                                        @GetFieldError(nameof(State.FormData.Description))
                                    </div>
                                }
                            </div>

                            <!-- Client Selection -->
                            <div class="mb-3">
                                <label for="clientSelect" class="form-label">
                                    Client <span class="text-danger">*</span>
                                </label>
                                <select class="form-select @(HasFieldError(nameof(State.FormData.ClientId)) ? "is-invalid" : "")" 
                                        id="clientSelect"
                                        @onchange="HandleClientSelected"
                                        disabled="@State.IsSubmitting">
                                    <option value="">-- Select a Client --</option>
                                    @foreach (var client in State.AvailableClients)
                                    {
                                        <option value="@client.Id">@client.Name</option>
                                    }
                                </select>
                                @if (HasFieldError(nameof(State.FormData.ClientId)))
                                {
                                    <div class="invalid-feedback d-block">
                                        @GetFieldError(nameof(State.FormData.ClientId))
                                    </div>
                                }
                            </div>

                            <!-- Manager Selection -->
                            <div class="mb-3">
                                <label for="managerSelect" class="form-label">
                                    Project Manager <span class="text-danger">*</span>
                                </label>
                                <select class="form-select @(HasFieldError(nameof(State.FormData.ManagerId)) ? "is-invalid" : "")" 
                                        id="managerSelect"
                                        @onchange="HandleManagerSelected"
                                        disabled="@State.IsSubmitting">
                                    <option value="">-- Select a Manager --</option>
                                    @foreach (var manager in State.AvailableManagers)
                                    {
                                        <option value="@manager.Id">@manager.FullName</option>
                                    }
                                </select>
                                @if (HasFieldError(nameof(State.FormData.ManagerId)))
                                {
                                    <div class="invalid-feedback d-block">
                                        @GetFieldError(nameof(State.FormData.ManagerId))
                                    </div>
                                }
                            </div>

                            <!-- Dates Row -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="startDate" class="form-label">Start Date</label>
                                        <input type="date" 
                                               class="form-control" 
                                               id="startDate"
                                               @bind="State.FormData.StartDate"
                                               @onchange="HandleStartDateChanged"
                                               disabled="@State.IsSubmitting" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="deadline" class="form-label">Deadline</label>
                                        <input type="date" 
                                               class="form-control @(HasFieldError(nameof(State.FormData.Deadline)) ? "is-invalid" : "")" 
                                               id="deadline"
                                               @bind="State.FormData.Deadline"
                                               @onchange="HandleDeadlineChanged"
                                               disabled="@State.IsSubmitting" />
                                        @if (HasFieldError(nameof(State.FormData.Deadline)))
                                        {
                                            <div class="invalid-feedback d-block">
                                                @GetFieldError(nameof(State.FormData.Deadline))
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Priority -->
                            <div class="mb-3">
                                <label for="priority" class="form-label">Priority (1-5)</label>
                                <input type="number" 
                                       class="form-control @(HasFieldError(nameof(State.FormData.Priority)) ? "is-invalid" : "")" 
                                       id="priority"
                                       min="1" 
                                       max="5"
                                       @bind="State.FormData.Priority"
                                       @onchange="e => HandleFieldChanged(nameof(State.FormData.Priority), e.Value)"
                                       disabled="@State.IsSubmitting" />
                                @if (HasFieldError(nameof(State.FormData.Priority)))
                                {
                                    <div class="invalid-feedback d-block">
                                        @GetFieldError(nameof(State.FormData.Priority))
                                    </div>
                                }
                            </div>
                        </form>
                    }
                </div>

                <!-- ===== MODAL FOOTER ===== -->
                <div class="modal-footer">
                    <button type="button" 
                            class="btn btn-secondary" 
                            @onclick="HandleCloseAsync"
                            disabled="@State.IsProcessing">
                        Cancel
                    </button>
                    <button type="button" 
                            class="btn btn-primary" 
                            @onclick="HandleSubmitAsync"
                            disabled="@(!State.IsFormValid || State.IsLoadingData)">
                        @if (State.IsSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @State.SubmitButtonText
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>
}