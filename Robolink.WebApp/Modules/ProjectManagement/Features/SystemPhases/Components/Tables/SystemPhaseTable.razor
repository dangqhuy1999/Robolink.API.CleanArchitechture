
<div class="table-responsive">
    <table class="table table-hover table-striped table-sm">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Sequence</th>
                <th>Status</th>
                <th>Usage</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var phase in Phases ?? new List<SystemPhaseDto>())
            {
                <tr class="phase-row">
                    <td>
                        <strong>@phase.Name</strong>
                    </td>
                    <td>
                        @phase.Description
                    </td>
                    <td>
                        <SystemPhaseSequenceBadge Sequence="phase.DefaultSequence" />
                    </td>
                    <td>
                        <SystemPhaseStatusBadge IsActive="phase.IsActive" />
                    </td>
                    <td>
                        <SystemPhaseUsageBadge UsageCount="GetUsageCount(phase.Id)" />
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-primary" 
                                    @onclick="() => HandleEdit(phase.Id)"
                                    title="Edit Phase">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" 
                                    @onclick="() => HandleDelete(phase.Id)"
                                    disabled="@(GetUsageCount(phase.Id) > 0)"
                                    title="Delete Phase">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<style>
    .phase-row {
        transition: background-color 0.2s ease;
    }

        .phase-row:hover {
            background-color: #f8f9fa;
        }

</style>
