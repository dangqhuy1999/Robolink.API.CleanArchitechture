@page "/projects/{ProjectId:guid}"


<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/projects" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            @if (CurrentProject != null) {
                <h1>@CurrentProject.Name</h1>
                <p class="text-muted">@CurrentProject.Description</p>
            }
             else if (!string.IsNullOrEmpty(ErrorMessage)) {
                <div class="alert alert-danger">@ErrorMessage</div>
            }
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="OpenAddPhaseModal">
                <i class="bi bi-plus-circle"></i> Add New Phase
            </button>
            <button class="btn btn-secondary" @onclick="RefreshPhases">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    <ProjectStatCards Project="CurrentProject" />

    <hr />

    <h3 class="mb-4">
        <i class="bi bi-diagram-3"></i> Project Phases 
        <span class="badge bg-secondary">@(ProjectPhases?.Count ?? 0)</span>
    </h3>

    @if (IsLoading) {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!string.IsNullOrEmpty(PhasesErrorMessage)) {
        <div class="alert alert-danger">@PhasesErrorMessage</div>
    }
    else if (ProjectPhases == null || !ProjectPhases.Any()) {
        <div class="alert alert-info">No phases assigned yet.</div>
    }
    else {
        <div class="row g-4">
            @foreach (var phase in ProjectPhases)
            {
                <div class="col-lg-4 col-md-6">
                    <ProjectPhaseCard Phase="phase"
                        OnClick="ViewPhaseTasks"
                        OnDelete=RemovePhase />
                </div>
            }
        </div>
    }
</div>
<AddPhaseModal ShowModal="showAddPhaseModal"
               AssignedSystemPhaseIds="ProjectPhases?.Select(p => p.SystemPhaseId).ToList()"
               OnClose="() => showAddPhaseModal = false"
               OnAssign="AssignPhase" />

<EditPhaseConfigModal ShowModal="showEditConfigModal"
                      Phase="selectedConfig"
                      OnModalClose="() => showEditConfigModal = false"
                      OnConfigChanged="RefreshPhases" />