@using Robolink.Shared.DTOs
@using Robolink.WebApp.Components.Features.Projects.Shared
@using Robolink.WebApp.Modules.ProjectManagement.Features.Projects.Shared

<div class="table-responsive">
    <table class="table table-hover table-striped table-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 50px;"></th>
                <th>Code</th>
                <th>Name</th>
                <th>Client</th>
                <th>Manager</th>
                <th>Start Date</th>
                <th>Deadline</th>
                <th>Status</th>
                <th>Priority</th>
                <th>InternalBudget</th>
                <th>CustomerBudget</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Projects)
            {
                <!-- ✅ MAIN PROJECT ROW - CLICKABLE FOR NAVIGATION -->
                <tr class="project-row cursor-pointer" @onclick="() => HandleViewProject(project.Id)" style="cursor: pointer;">
                    <!-- ✅ CHEVRON EXPAND/COLLAPSE BUTTON (FIXED) -->
                    <td class="text-center" @onclick:stopPropagation="true">
                        @if (project.SubProjects?.Any() == true)
                        {
                            <button class="btn btn-sm btn-outline-primary chevron-btn" 
                                    @onclick="() => HandleToggleExpand(project.Id)"
                                    style="padding: 2px 8px; min-width: 40px;">
                                @if (IsExpanded(project.Id))
                                {
                                    <i class="bi bi-chevron-down"></i>
                                }
                                else
                                {
                                    <i class="bi bi-chevron-right"></i>
                                }
                            </button>
                        }
                        else
                        {
                            <span style="display: inline-block; width: 40px;"></span>
                        }
                    </td>

                    <td>
                        <span class="badge bg-info">@project.ProjectCode</span>
                    </td>

                    <td>
                        <strong>@project.Name</strong>
                    </td>

                    <td>
                        @project.ClientName
                    </td>

                    <td>
                        @project.ManagerName
                    </td>

                    <!-- ✅ NEW: Start Date Column -->
                    <td>
                        <small>@project.StartDate.ToString("yyyy-MM-dd")</small>
                    </td>

                    <!-- ✅ NEW: Deadline Column -->
                    <td>
                        <small>@project.Deadline.ToString("yyyy-MM-dd")</small>
                    </td>

                    <td>
                        <ProjectStatusBadge Status="project.Status" />
                    </td>

                    <td>
                        <ProjectPriorityBadge Priority="project.Priority" />
                    </td>

                    <td>
                        <strong>$@(project.InternalBudget?.ToString("F0") ?? "-")</strong>
                    </td>
                    <td>
                        <strong>$@(project.CustomerBudget?.ToString("F0") ?? "-")</strong>
                    </td>
                    <td @onclick:stopPropagation="true">
                        <!-- Action Buttons (FIXED LAMBDA) -->
                        <div class="btn-group" role="group">
                            <!-- View/Manage Button -->
                            <button class="btn btn-sm btn-info" 
                                    @onclick="() => HandleViewProject(project.Id)"
                                    title="Manage Project Phases">
                                <i class="bi bi-diagram-3"></i>
                            </button>

                            <!-- Edit Button -->
                            <button class="btn btn-sm btn-primary" 
                                    @onclick="() => HandleEdit(project.Id)"
                                    title="Edit Project">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <!-- Add Sub Button -->
                            <button class="btn btn-sm btn-warning" 
                                    @onclick="() => HandleAddSub(project.Id)"
                                    title="Add sub-project">
                                <i class="bi bi-plus-circle"></i>
                            </button>

                            <!-- Delete Button -->
                            <button class="btn btn-sm btn-danger" 
                                    @onclick="() => HandleDelete(project.Id)"
                                    title="Delete Project">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- ✅ SUB-PROJECTS ROWS (Expandable) -->
                @if (project.SubProjects?.Any() == true && IsExpanded(project.Id))
                {
                    @foreach (var subProject in project.SubProjects)
                    {
                        <tr class="sub-project-row cursor-pointer" @onclick="() => HandleViewProject(subProject.Id)" style="cursor: pointer;">
                            <td></td>
                            <td>
                                <span class="badge bg-secondary">@subProject.ProjectCode</span>
                            </td>
                            <td>
                                <strong style="margin-left: 20px;">↳ @subProject.Name</strong>
                            </td>
                            <td>@subProject.ClientName</td>
                            <td>@subProject.ManagerName</td>
                            <td><small>@subProject.StartDate.ToString("yyyy-MM-dd")</small></td>
                            <td><small>@subProject.Deadline.ToString("yyyy-MM-dd")</small></td>
                            <td><ProjectStatusBadge Status="subProject.Status" /></td>
                            <td><ProjectPriorityBadge Priority="subProject.Priority" /></td>
                            <td><strong>$@(subProject.InternalBudget?.ToString("F0") ?? "-")</strong></td>
                            <td><strong>$@(subProject.CustomerBudget?.ToString("F0") ?? "-")</strong></td>
                            <td @onclick:stopPropagation="true">
                                <div class="btn-group" role="group">
                                    <button class="btn btn-sm btn-info" 
                                            @onclick="() => HandleViewProject(subProject.Id)"
                                            title="Manage Project Phases">
                                        <i class="bi bi-diagram-3"></i>
                                    </button>
                                    <button class="btn btn-sm btn-primary" 
                                            @onclick="() => HandleEdit(subProject.Id)"
                                            title="Edit Project">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" 
                                            @onclick="() => HandleDelete(subProject.Id)"
                                            title="Delete Project">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>


<style>
    .cursor-pointer {
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    .project-row:hover {
        background-color: #f8f9fa;
    }

    .sub-project-row:hover {
        background-color: #fff3cd;
    }

</style>
