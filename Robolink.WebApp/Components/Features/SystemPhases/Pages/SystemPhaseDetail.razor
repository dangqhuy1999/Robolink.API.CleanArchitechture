@page "/system-phases/{PhaseId:guid}"

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>⚙️ System Phase Details</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="() => EditMode = !EditMode">
                <i class="bi bi-pencil"></i> @(EditMode ? "Cancel" : "Edit")
            </button>
            <button class="btn btn-secondary" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Back
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Loading...
        </div>
    }
    else if (phase == null)
    {
        <div class="alert alert-danger">Phase not found</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h5>Phase Information</h5>
                    </div>
                    <div class="card-body">
                        @if (!EditMode)
                        {
                            <div class="mb-3">
                                <label class="form-label"><strong>Name</strong></label>
                                <p>@phase.Name</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label"><strong>Description</strong></label>
                                <p>@phase.Description</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label"><strong>Default Sequence</strong></label>
                                <p>@phase.DefaultSequence</p>
                            </div>
                            <div class="mb-3">
                                <label class="form-label"><strong>Status</strong></label>
                                <p>@(phase.IsActive ? "Active" : "Inactive")</p>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="formName">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" @bind="formDescription" rows="3"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Default Sequence</label>
                                <input type="number" class="form-control" @bind="formSequence" min="1">
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" @bind="formIsActive" id="isActive">
                                <label class="form-check-label" for="isActive">Active</label>
                            </div>
                            <button class="btn btn-success" @onclick="SaveChanges">Save</button>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">
                        <h5>Usage Statistics</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Used by Projects:</strong> @UsageCount</p>
                        <p><strong>Created:</strong> @phase.CreatedAt.ToString("MMM dd, yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

