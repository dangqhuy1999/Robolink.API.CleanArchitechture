<div class="modal @(ShowModal ? "show d-block" : "")" style="background: @(ShowModal ? "rgba(0,0,0,0.5)" : "");">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Edit Project
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="alert alert-info">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </div>
                }
                else if (project == null)
                {
                    <div class="alert alert-danger">Project not found</div>
                }
                else
                {
                    <form @onsubmit="HandleUpdateProject">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Code</label>
                                <input type="text" class="form-control" value="@project.ProjectCode" disabled />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Name</label>
                                <InputText class="form-control" @bind-Value="updateRequest.Name" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="updateRequest.Description" rows="2" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Manager</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.ManagerId">
                                    <option value="">-- Select Manager --</option>
                                    @if (managers != null)
                                    {
                                        @foreach (var staff in managers)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Status">
                                    <option value="">-- Select Status --</option>
                                    <option value="0">Draft</option>
                                    <option value="1">In Progress</option>
                                    <option value="2">Completed</option>
                                    <option value="3">On Hold</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- ✅ NEW: Parent Project Selector -->
                        <ParentProjectSelector 
                            @bind-SelectedParentId="updateRequest.ParentProjectId"
                            ExcludeProjectId="project.Id"
                            CurrentParentName="@project.ParentProjectName" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deadline</label>
                                <InputDate class="form-control" @bind-Value="updateRequest.Deadline" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Priority">
                                    <option value="">-- Select Priority --</option>
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2">High</option>
                                    <option value="3">Critical</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Internal Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.InternalBudget" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.CustomerBudget" />
                            </div>
                        </div>

                        <!-- ✅ NEW: Display Sub-Projects -->
                        @if (project.SubProjects?.Any() == true)
                        {
                            <div class="mb-3">
                                <label class="form-label"><i class="bi bi-diagram-3"></i> Sub-Projects</label>
                                <SubProjectsList 
                                    SubProjects="project.SubProjects" 
                                    OnSelectSubProject="SelectSubProject" />
                            </div>
                        }

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
