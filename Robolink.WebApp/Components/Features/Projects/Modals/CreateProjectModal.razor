<div class="modal @(ShowModal ? "show d-block" : "")" tabindex="-1" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i>
                    @if (request.ParentProjectId.HasValue && request.ParentProjectId != Guid.Empty)
                    {
                        <span>Create Sub-Project</span>
                    }
                    else
                    {
                        <span>Create New Project</span>
                    }
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="alert alert-info">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </div>
                }
                else
                {
                    <form @onsubmit="HandleCreateProject">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Code</label>
                                <input type="text" class="form-control" @bind="request.ProjectCode" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Name</label>
                                <input type="text" class="form-control" @bind="request.Name" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="request.Description" rows="2"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Client</label>
                                <InputSelect class="form-control" @bind-Value="request.ClientId">
                                    <option value="">-- Select Client --</option>
                                    @if (clients != null)
                                    {
                                        @foreach (var client in clients)
                                        {
                                            <option value="@client.Id">@client.Name</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Project Manager</label>
                                <InputSelect class="form-control" @bind-Value="request.ManagerId">
                                    <option value="">-- Select Manager --</option>
                                    @if (managers != null)
                                    {
                                        @foreach (var staff in managers)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <!-- ✅ Parent Project Selector -->
                        <ParentProjectSelector 
                            @bind-SelectedParentId="request.ParentProjectId"
                            ExcludeProjectId="null"
                            CurrentParentName="null" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="request.StartDate" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deadline</label>
                                <InputDate class="form-control" @bind-Value="request.Deadline" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-control" @bind-Value="request.Priority">
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2">High</option>
                                    <option value="3">Critical</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Internal Budget</label>
                                <InputNumber class="form-control" @bind-Value="request.InternalBudget" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Customer Budget</label>
                            <InputNumber class="form-control" @bind-Value="request.CustomerBudget" />
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Create Project
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
