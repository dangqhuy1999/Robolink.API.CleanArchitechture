@using Robolink.Application.DTOs
@using Robolink.WebApp.Components.Features.PhaseTasks.Shared

<div class="table-responsive">
    <table class="table table-hover table-striped table-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 50px;"></th>
                <th>Description</th>
                <th>Assigned To</th>
                <th>Due Date</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Progress</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var phaseTask in PhaseTasks)
            {
                <!-- ✅ MAIN PROJECT ROW - CLICKABLE FOR NAVIGATION -->
                <tr class="project-row cursor-pointer" @onclick="() => HandleViewPhaseTask(phaseTask.Id)" style="cursor: pointer;">
                    <!-- ✅ CHEVRON EXPAND/COLLAPSE BUTTON (FIXED) -->
                    <td class="text-center" @onclick:stopPropagation="true">
                        @if (phaseTask.SubPhaseTasks?.Any() == true)
                        {
                            <button class="btn btn-sm btn-outline-primary chevron-btn" 
                                    @onclick="() => HandleToggleExpand(phaseTask.Id)"
                                    style="padding: 2px 8px; min-width: 40px;">
                                @if (IsExpanded(phaseTask.Id))
                                {
                                    <i class="bi bi-chevron-down"></i>
                                }
                                else
                                {
                                    <i class="bi bi-chevron-right"></i>
                                }
                            </button>
                        }
                        else
                        {
                            <span style="display: inline-block; width: 40px;"></span>
                        }
                    </td>

                    <td>
                        <span class="badge bg-info">@phaseTask.Description</span>
                    </td>

                    <td>
                        <strong>@phaseTask.AssignedStaffName</strong>
                    </td>

                    <!-- ✅ NEW: Start Date Column -->
                    <td>
                        <small>@phaseTask.DueDate.ToString("yyyy-MM-dd")</small>
                    </td>

                    <td>
                        <TaskStatusBadge Status="(int)phaseTask.Status" />
                    </td>

                    <td>
                        <TaskPriorityBadge Priority="phaseTask.Priority" />
                    </td>

                    <td @onclick:stopPropagation="true">
                        <!-- Action Buttons (FIXED LAMBDA) -->
                        <div class="btn-group" role="group">
                            <!-- View/Manage Button -->
                            <button class="btn btn-sm btn-info" 
                                    @onclick="() => HandleViewPhaseTask(phaseTask.Id)"
                                    title="View details">
                                <i class="bi bi-diagram-3"></i>
                            </button>

                            <!-- Edit Button -->
                            <button class="btn btn-sm btn-primary" 
                                    @onclick="() => HandleEdit(phaseTask.Id)"
                                    title="Edit Task">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <!-- Add Sub Button -->
                            <button class="btn btn-sm btn-warning" 
                                    @onclick="() => HandleAddSub(phaseTask.Id)"
                                    title="Add sub-task">
                                <i class="bi bi-plus-circle"></i>
                            </button>

                            <!-- Delete Button -->
                            <button class="btn btn-sm btn-danger" 
                                    @onclick="() => HandleDelete(phaseTask.Id)"
                                    title="Delete Task">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- ✅ SUB-PROJECTS ROWS (Expandable) -->
                @if (phaseTask.SubPhaseTasks?.Any() == true && IsExpanded(phaseTask.Id))
                {
                    @foreach (var subPhaseTask in phaseTask.SubPhaseTasks)
                    {
                        <tr class="sub-project-row cursor-pointer" @onclick="() => HandleViewPhaseTask(subPhaseTask.Id)" style="cursor: pointer;">
                            <td></td>
                            <td>
                                <span class="badge bg-secondary">@subPhaseTask.Description</span>
                            </td>
                            <td>
                                <strong style="margin-left: 20px;">↳ @subPhaseTask.AssignedStaffName</strong>
                            </td>
                            <!-- ✅ NEW: Start Date Column -->
                            <td>
                                <small>@phaseTask.DueDate.ToString("yyyy-MM-dd")</small>
                            </td>

                            <td>
                                <TaskStatusBadge Status="(int)phaseTask.Status" />
                            </td>

                            <td>
                                <TaskPriorityBadge Priority="phaseTask.Priority" />
                            </td>

                            <td @onclick:stopPropagation="true">
                                <!-- Action Buttons (FIXED LAMBDA) -->
                                <div class="btn-group" role="group">
                                    <!-- View/Manage Button -->
                                    <button class="btn btn-sm btn-info"
                                            @onclick="() => HandleViewPhaseTask(phaseTask.Id)"
                                            title="View details">
                                        <i class="bi bi-diagram-3"></i>
                                    </button>

                                    <!-- Edit Button -->
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="() => HandleEdit(phaseTask.Id)"
                                            title="Edit Task">
                                        <i class="bi bi-pencil"></i>
                                    </button>

                                    <!-- Add Sub Button -->
                                    <button class="btn btn-sm btn-warning"
                                            @onclick="() => HandleAddSub(phaseTask.Id)"
                                            title="Add sub-task">
                                        <i class="bi bi-plus-circle"></i>
                                    </button>

                                    <!-- Delete Button -->
                                    <button class="btn btn-sm btn-danger"
                                            @onclick="() => HandleDelete(phaseTask.Id)"
                                            title="Delete Task">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            }
        </tbody>
        </table>
</div>

@code {
    [Parameter]
    public List<PhaseTaskDto> PhaseTasks { get; set; } = new();

    [Parameter]
    public EventCallback<Guid> OnEdit { get; set; }

    [Parameter]
    public EventCallback<Guid> OnDelete { get; set; }

    [Parameter]
    public EventCallback<Guid> OnAddSubPhaseTask { get; set; }

    [Parameter]
    public EventCallback<Guid> OnViewPhaseTask { get; set; } // ✅ NEW: Event for viewing project

    [Parameter]
    public EventCallback OnRefresh { get; set; }

    private HashSet<Guid> expandedPhaseTasks = new();

    // ✅ NEW: Handle View/Navigate to Project Management
    private async Task HandleViewPhaseTask(Guid phaseTaskId)
    {
        await OnViewPhaseTask.InvokeAsync(phaseTaskId);
    }

    private async Task HandleEdit(Guid projectId)
    {
        await OnEdit.InvokeAsync(projectId);
    }

    private async Task HandleDelete(Guid projectId)
    {
        await OnDelete.InvokeAsync(projectId);
    }

    private async Task HandleAddSub(Guid projectId)
    {
        await OnAddSubPhaseTask.InvokeAsync(projectId);
    }

    private void HandleToggleExpand(Guid projectId)
    {
        if (expandedPhaseTasks.Contains(projectId))
        {
            expandedPhaseTasks.Remove(projectId);
        }
        else
        {
            expandedPhaseTasks.Add(projectId);
        }
    }

    private bool IsExpanded(Guid projectId) => expandedPhaseTasks.Contains(projectId);
}

<style>
    .cursor-pointer {
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    .project-row:hover {
        background-color: #f8f9fa;
    }

    .sub-project-row:hover {
        background-color: #fff3cd;
    }
</style>