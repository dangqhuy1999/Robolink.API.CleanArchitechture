@using Robolink.Application.DTOs

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <button class="btn btn-outline-secondary btn-sm" @onclick="OnBack">
            <i class="bi bi-arrow-left"></i> Back to Phases
        </button>
        @if (PhaseConfig != null)
        {
            <h2 class="mt-3">
                <i class="bi bi-diagram-3"></i> @GetPhaseName()
            </h2>
            <p class="text-muted">@PhaseConfig.SystemPhase?.Description</p>
        }
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-success" @onclick="OnAddTask" disabled="@(IsLoading || PhaseConfig == null)">
            <i class="bi bi-plus-circle"></i> Add Task
        </button>
        <button class="btn btn-secondary" @onclick="OnRefresh">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
</div>

@code {
    [Parameter]
    public ProjectPhaseConfigDto? PhaseConfig { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public EventCallback OnAddTask { get; set; }

    [Parameter]
    public EventCallback OnRefresh { get; set; }

    private string GetPhaseName()
    {
        return PhaseConfig?.CustomPhaseName ?? PhaseConfig?.SystemPhase?.Name ?? "Unknown Phase";
    }
}