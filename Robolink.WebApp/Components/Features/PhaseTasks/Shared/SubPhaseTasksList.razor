@using Robolink.Application.DTOs

@if (SubPhaseTasks?.Any() == true)
{
    <div class="alert alert-light border-start border-info border-3 py-2">
        <small class="text-muted">
            <i class="bi bi-diagram-3"></i>
            <strong>Sub-PhaseTasks (@SubPhaseTasks.Count):</strong>
        </small>
        <div class="mt-2 d-flex flex-wrap gap-2">
            @foreach (var subTask in SubPhaseTasks)
            {
                <span class="badge bg-info-subtle text-info-emphasis" 
                      style="cursor: pointer;"
                      @onclick="() => OnSelectSubPhaseTask.InvokeAsync(subTask.Id)"
                      title="Click to view">
                    @subTask.Description
                </span>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public List<PhaseTaskDto>? SubPhaseTasks { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelectSubPhaseTask { get; set; }
}