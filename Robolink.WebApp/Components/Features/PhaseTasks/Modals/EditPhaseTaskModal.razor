@using MediatR
@using Robolink.Application.Commands.PhaseTasks
@using Robolink.Application.Queries.PhaseTasks
@using Robolink.Application.Queries.Clients
@using Robolink.Application.Queries.Staff
@using Robolink.Application.DTOs
@using Robolink.Core.Enums
@using Robolink.WebApp.Components.Features.PhaseTasks.Shared
@inject IMediator Mediator
@inject IJSRuntime JSRuntime

<div class="modal @(ShowModal ? "show d-block" : "")" style="background: @(ShowModal ? "rgba(0,0,0,0.5)" : "");">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Edit Task
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="alert alert-info">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </div>
                }
                else if (phaseTask == null)
                {
                    <div class="alert alert-danger">Task not found.</div>
                }
                else
                {
                    <form @onsubmit="HandleUpdatePhaseTask">
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="updateRequest.Description" rows="2" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Staff Management</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.AssignedStaffId">
                                    <option value="">-- Select Staff --</option>
                                    @if (staffs!= null)
                                    {
                                        @foreach (var staff in staffs)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Status">
                                    <option value="">-- Select Status --</option>
                                    <option value="0">Draft</option>
                                    <option value="1">In Progress</option>
                                    <option value="2">Completed</option>
                                    <option value="3">On Hold</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- ✅ NEW: Parent Project Selector -->
                        <ParentPhaseTaskSelector 
                            @bind-SelectedParentId="updateRequest.ParentPhaseTaskId"
                            ExcludeProjectId="phaseTask.Id"
                            CurrentParentName="@phaseTask.ParentPhaseTaskName" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deadline</label>
                                <InputDate class="form-control" @bind-Value="updateRequest.DueDate" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Priority">
                                    <option value="">-- Select Priority --</option>
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2">High</option>
                                    <option value="3">Critical</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Internal Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.InternalBudget" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.CustomerBudget" />
                            </div>
                        </div>

                        <!-- ✅ NEW: Display Sub-Projects -->
                        @if (phaseTask.SubPhaseTasks?.Any() == true)
                        {
                            <div class="mb-3">
                                <label class="form-label"><i class="bi bi-diagram-3"></i> Sub-PhaseTasks</label>
                                <SubPhaseTasksList 
                                    SubPhaseTasks="phaseTask.SubPhaseTasks" 
                                    OnSelectSubPhaseTask="SelectSubPhaseTask" />
                            </div>
                        }

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool ShowModal { get; set; }
    [Parameter] public Guid PhaseTaskId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private PhaseTaskDto? phaseTask;
    private UpdatePhaseTaskRequest updateRequest = new();
    private List<StaffDto> staffs = new();
    private bool isLoading = false;

    protected override async Task OnParametersSetAsync()
    {
        if (ShowModal && PhaseTaskId != Guid.Empty)
        {
            isLoading = true;
            await LoasPhaseTask();
            await LoadManagers();
            isLoading = false;
        }
    }

    private async Task LoasPhaseTask()
    {
        try
        {
            phaseTask = await Mediator.Send(new GetPhaseTaskByIdQuery(PhaseTaskId));
            if (phaseTask!= null)
            {
                updateRequest = new UpdatePhaseTaskRequest
                {
                    Description = phaseTask.Description,
                    AssignedStaffId = phaseTask.AssignedStaffId,
                    DueDate = phaseTask.DueDate,
                    Status = phaseTask.Status, // Chuyển từ Enum sang int nếu cần
                    Priority = phaseTask.Priority,
                    EstimatedHours = phaseTask.EstimatedHours,
                    ParentPhaseTaskId = phaseTask.ParentPhaseTaskId,

                    // Nếu trong DB có Budget thì gán vào, nếu không hãy xóa dòng này
                    InternalBudget = phaseTask.InternalBudget,
                    CustomerBudget = phaseTask.CustomerBudget
                };
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading project: {ex.Message}");
        }
    }

    private async Task LoadManagers()
    {
        try
        {
            var result = await Mediator.Send(new GetAllStaffQuery());
            staffs = result?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error loading managers: {ex.Message}");
        }
    }

    private async Task HandleUpdatePhaseTask()
    {
        try
        {
            var result = await Mediator.Send(new UpdatePhaseTaskCommand
            {
                Id = updateRequest.Id,                                 // ID của Task đang sửa (lấy từ Parameter)
                Description = updateRequest.Description,              // Nội dung mô tả
                AssignedStaffId = updateRequest.AssignedStaffId,      // Nhân viên thực hiện
                DueDate = updateRequest.DueDate,                      // Hạn chót
                Status = updateRequest.Status,                        // Trạng thái (Enum)
                Priority = updateRequest.Priority,                    // Mức độ ưu tiên
                EstimatedHours = updateRequest.EstimatedHours,        // Giờ dự kiến
                ParentPhaseTaskId = updateRequest.ParentPhaseTaskId,  // ID Task cha (nếu có)
                CreatedBy = "Huy Dang"                                // Tên người cập nhật
            });

            if (result != null)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Project updated successfully!");
                await OnSaved.InvokeAsync();
                await CloseModal();
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private async Task SelectSubPhaseTask(Guid subProjectId)
    {
        // Close current modal and open the sub-project
        await CloseModal();
        // This would be handled by parent component
    }

    private async Task CloseModal()
    {
        phaseTask = null;
        updateRequest = new();
        await OnClose.InvokeAsync();
    }
}