
<div class="modal @(ShowModal ? "show d-block" : "")" style="background: @(ShowModal ? "rgba(0,0,0,0.5)" : "");">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Edit Task
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="alert alert-info">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </div>
                }
                else if (phaseTask == null)
                {
                    <div class="alert alert-danger">Task not found.</div>
                }
                else
                {
                    <form @onsubmit="HandleUpdatePhaseTask">
                        <div class="mb-3">
                            <label class="form-label">Task Name</label>
                            <InputText class="form-control" @bind-Value="updateRequest.Name" placeholder="Enter task name..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="updateRequest.Description" rows="2" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Staff Management</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.AssignedStaffId">
                                    <option value="@((Guid?)null)">-- Select Staff --</option>
                                    @if (staffs!= null)
                                    {
                                        @foreach (var staff in staffs)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Status">
                                    <option value="">-- Select Status --</option>
                                    <option value="@((int)Task_Status.Cancelled)">Cancelled</option>
                                    <option value="@((int)Task_Status.InProgress)">In Progress</option>
                                    <option value="@((int)Task_Status.Completed)">Completed</option>
                                    <option value="@((int)Task_Status.OnHold)">On Hold</option>
                                </InputSelect>
                            </div>
                        </div>

                        <ParentPhaseTaskSelector 
                            ProjectId="phaseTask.ProjectId" 
                            ProjectSystemPhaseConfigId="phaseTask.ProjectSystemPhaseConfigId"
                            @bind-SelectedParentId="updateRequest.ParentPhaseTaskId"
                            ExcludePhaseTaskId="phaseTask.Id"
                            CurrentParentName="@phaseTask.ParentPhaseTaskName" />
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Deadline</label>
                                <InputDate class="form-control" @bind-Value="updateRequest.DueDate" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-control" @bind-Value="updateRequest.Priority">
                                    <option value="">-- Select Priority --</option>
                                    <option value="@((int)0)">Low</option>
                                    <option value="@((int)1)">Medium</option>
                                    <option value="@((int)2)">High</option>
                                    <option value="@((int)3)">Critical</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Estimated Hours</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.EstimatedHours" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Internal Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.InternalBudget" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Customer Budget</label>
                                <InputNumber class="form-control" @bind-Value="updateRequest.CustomerBudget" />
                            </div>
                        </div>

                        @if (phaseTask.SubPhaseTasks?.Any() == true)
                        {
                            <div class="mb-3">
                                <label class="form-label"><i class="bi bi-diagram-3"></i> Sub-PhaseTasks</label>
                                <SubPhaseTasksList 
                                    SubPhaseTasks="phaseTask.SubPhaseTasks" 
                                    OnSelectSubPhaseTask="SelectSubPhaseTask" />
                            </div>
                        }

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
