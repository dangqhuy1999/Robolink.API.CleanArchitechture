@using Robolink.Application.Commands.PhaseTasks
@using Robolink.Application.DTOs
@using Robolink.Application.Queries.Staff
@using Robolink.Application.Queries.ProjectPhases
@using MediatR
@inject IMediator Mediator
@inject IJSRuntime JSRuntime

<div class="modal @(ShowModal ? "show d-block" : "")" style="background-color: @(ShowModal ? "rgba(0,0,0,0.5)" : "transparent")">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i> @(string.IsNullOrEmpty(ParentTaskName) ? "Create New Task" : $"Create Sub-task for: {ParentTaskName}")
                </h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="text-center">
                        <div class="spinner-border" role="status"></div>
                        <p class="mt-2">Loading...</p>
                    </div>
                }
                else
                {
                    <form @onsubmit="SubmitCreateTask">
                        <!-- Task Description -->
                        <div class="mb-3">
                            <label class="form-label">Task Description *</label>
                            <textarea class="form-control" @bind="request.Description" 
                                      rows="3" placeholder="Enter task description" required></textarea>
                        </div>

                        <!-- Assigned Staff -->
                        <div class="mb-3">
                            <label class="form-label">Assign To *</label>
                            <select class="form-control" @bind="request.AssignedStaffId" required>
                                <option value="">-- Select Staff --</option>
                                @if (staffList != null)
                                {
                                    @foreach (var staff in staffList)
                                    {
                                        <option value="@staff.Id">@staff.FullName</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Due Date -->
                        <div class="mb-3">
                            <label class="form-label">Due Date *</label>
                            <input type="date" class="form-control" @bind="request.DueDate" required />
                        </div>

                        <!-- Priority -->
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <select class="form-control" @bind="request.Priority">
                                <option value="0">⚪ Low</option>
                                <option value="1">🔵 Medium</option>
                                <option value="2">🟠 High</option>
                                <option value="3">🔴 Critical</option>
                            </select>
                        </div>

                        <!-- Estimated Hours -->
                        <div class="mb-3">
                            <label class="form-label">Estimated Hours</label>
                            <input type="number" class="form-control" @bind="request.EstimatedHours" 
                                   placeholder="e.g., 8" step="0.5" min="0" />
                        </div>

                        <!-- Error Message -->
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger">@errorMessage</div>
                        }

                        <!-- Submit -->
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="OnClose">Cancel</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Create Task
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool ShowModal { get; set; }

    [Parameter]
    public Guid ProjectId { get; set; }

    [Parameter]
    public Guid PhaseId { get; set; }

    [Parameter]
    public Guid? ParentTaskId { get; set; }  // ✅ NEW: For subtasks

    [Parameter]
    public string? ParentTaskName { get; set; }  // ✅ NEW: Display parent name

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    private CreatePhaseTaskRequest request = new();
    private List<StaffDto> staffList = new();
    private bool isLoading = true;
    private string errorMessage = "";

    protected override async Task OnParametersSetAsync()
    {
        if (ShowModal && staffList.Count == 0)
        {
            await LoadStaff();
        }
    }

    private async Task LoadStaff()
    {
        isLoading = true;
        try
        {
            var query = new GetAllStaffQuery();
            staffList = (await Mediator.Send(query))?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading staff: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitCreateTask()
    {
        try
        {
            errorMessage = "";

            if (string.IsNullOrWhiteSpace(request.Description))
            {
                errorMessage = "Task description is required";
                return;
            }

            if (request.AssignedStaffId == Guid.Empty)
            {
                errorMessage = "Please assign a staff member";
                return;
            }

            request.ProjectId = ProjectId;
            request.ProjectSystemPhaseConfigId = PhaseId;
            request.ParentPhaseTaskId = ParentTaskId;  // ✅ NEW: Set parent ID for subtasks

            var command = new CreatePhaseTaskCommand
            {
                Request = request,
                CreatedBy = "Huy Dang"
            };

            var result = await Mediator.Send(command);

            if (result != null)
            {
                await OnSaved.InvokeAsync();
                await OnClose.InvokeAsync();
                await JSRuntime.InvokeVoidAsync("alert", "Task created successfully!");
                request = new();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            await JSRuntime.InvokeVoidAsync("alert", $"Error creating task: {ex.Message}");
        }
    }
}