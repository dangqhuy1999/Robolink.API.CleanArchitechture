

<div class="modal @(ShowModal ? "show d-block" : "")" tabindex="-1" style="background: @(ShowModal ? "rgba(0,0,0,0.5)" : "");">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-diagram-3-plus"></i> Quick Add Sub-Task
                </h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (parentPhaseTask == null)
                {
                    <div class="alert alert-danger">Parent task not found</div>
                }
                else if (isLoading)
                {
                    <div class="alert alert-info">
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Loading...
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-3">
                        <strong>Parent Task:</strong> @parentPhaseTask.InternalBudget - @parentPhaseTask.StartDate
                    </div>

                    <form @onsubmit="HandleCreateSubPhaseTask">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Task Name: </label>
                                <InputText class="form-control" @bind-Value="request.Name" placeholder="Type task name..."></InputText>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Description: </label>
                                @* Sửa lại *@
                                <InputTextArea class="form-control" @bind-Value="request.Description" rows="2" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Assignment To:</label>
                                <InputSelect class="form-control" @bind-Value="request.AssignedStaffId">
                                    <option value="">-- Select Staff --</option>
                                    @if (staffs != null)
                                    {
                                        @foreach (var staff in staffs)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Create By: </label>
                                <InputSelect class="form-control" @bind-Value="request.AssignedStaffId">
                                    <option value="">-- Select Staff --</option>
                                    @if (staffs != null)
                                    {
                                        @foreach (var staff in staffs)
                                        {
                                            <option value="@staff.Id">@staff.FullName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Deadline</label>
                                <InputDate class="form-control" @bind-Value="request.DueDate" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-control" @bind-Value="request.Priority">
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2">High</option>
                                    <option value="3">Critical</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Internal Budget</label>
                                <InputNumber class="form-control" @bind-Value="request.InternalBudget" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Customer Budget</label>
                            <InputNumber class="form-control" @bind-Value="request.CustomerBudget" />
                        </div>

                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Create Task
                                 s
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
