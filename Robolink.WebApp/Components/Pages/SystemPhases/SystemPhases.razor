@page "/system-phases"
@using Robolink.Application.DTOs
@using Robolink.WebApp.Components.Features.SystemPhases.Modals
@using Robolink.WebApp.Components.Features.SystemPhases.Tables
@using Robolink.WebApp.Components.Features.SystemPhases.Pagination

<div class="container-fluid mt-4">
    <!-- CONTROLS & ACTIONS -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>⚙️ System Phases Management</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="ShowCreateModal">
                <i class="bi bi-plus-lg"></i> New Phase
            </button>
            <button class="btn btn-secondary" @onclick="RefreshPhases">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    <!-- Loading State -->
    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Loading...
        </div>
    }
    else if (pagedPhases == null || !pagedPhases.Any())
    {
        <div class="alert alert-warning">
            No system phases found. <button class="btn btn-link" @onclick="ShowCreateModal">Create one</button>
        </div>
    }
    else
    {
        <!-- ✅ SYSTEM PHASES TABLE -->
        <SystemPhaseTable 
            Phases="pagedPhases" 
            OnEdit="ShowEditModal" 
            OnDelete="DeletePhase"
            OnRefresh="RefreshPhases" />

        <!-- ✅ PAGINATION -->
        <SystemPhasePagination 
            CurrentPage="currentPage" 
            TotalPages="totalPages" 
            TotalPhases="totalPhases"
            OnPageChanged="GoToPage" />
    }
</div>

<!-- MODALS -->
<CreateSystemPhaseModal 
    ShowModal="showCreateModal" 
    OnClose="HideCreateModal" 
    OnSaved="RefreshPhases" />

<EditSystemPhaseModal 
    ShowModal="showEditModal" 
    PhaseId="selectedPhaseId" 
    OnClose="HideEditModal" 
    OnSaved="RefreshPhases" />
