@page "/projects"
@using Robolink.Application.DTOs
@using Robolink.WebApp.Components.Features.Projects.Modals
@using Robolink.WebApp.Components.Features.Projects.Tables
@using Robolink.WebApp.Components.Features.Projects.Pagination

<div class="container-fluid mt-4">
    <!-- CONTROLS & ACTIONS -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📋 Projects Management</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-success" @onclick="ShowCreateModal">
                <i class="bi bi-plus-lg"></i> New Project
            </button>
            <button class="btn btn-info" @onclick="IncrementCount">
                <i class="bi bi-lightning-fill"></i> Quick Add
            </button>
            <button class="btn btn-secondary" @onclick="ShowSettings">
                <i class="bi bi-gear"></i> Settings
            </button>
        </div>
    </div>

    <!-- Loading State -->
    @if (isLoading)
    {
        <div class="alert alert-info">
            <span class="spinner-border spinner-border-sm me-2"></span>
            Loading...
        </div>
    }
    else if (projects == null || !projects.Any())
    {
        <div class="alert alert-warning">
            No projects found. <button class="btn btn-link" @onclick="ShowCreateModal">Create one</button>
        </div>
    }
    else
    {
        <!-- ✅ SINGLE TABLE VIEW -->
        <ProjectTable 
            Projects="projects" 
            OnEdit="ShowEditModal" 
            OnDelete="DeleteProject"
            OnAddSubProject="ShowQuickAddSubModal"
            OnRefresh="LoadProjects" />

        <!-- PAGINATION -->
        <ProjectPagination 
            CurrentPage="currentPage" 
            TotalPages="totalPages" 
            TotalProjects="totalProjects"
            OnPageChanged="GoToPage" />
    }
</div>      

<!-- MODALS -->
<CreateProjectModal 
    ShowModal="showCreateModal" 
    OnClose="HideCreateModal" 
    OnSaved="LoadProjects" />

<EditProjectModal 
    ShowModal="showEditModal" 
    ProjectId="selectedProjectId" 
    OnClose="HideEditModal" 
    OnSaved="LoadProjects" />

<QuickAddSubProjectModal
    ShowModal="showQuickAddSubModal"
    ParentProjectId="selectedProjectId"
    OnClose="HideQuickAddSubModal"
    OnSaved="LoadProjects" />