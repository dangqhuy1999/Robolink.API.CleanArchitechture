<div class="card phase-card h-100" @onclick="HandleClick">
    <div class="card-header bg-light">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-primary me-2">@Phase.Sequence</span>
                <strong>@PhaseName</strong>
            </div>
            @if (Phase.IsEnabled)
            {
                <span class="badge bg-success">✅ Active</span>
            }
            else
            {
                <span class="badge bg-secondary">⭕ Inactive</span>
            }
        </div>
    </div>

    <div class="card-body">
        @if (Phase.SystemPhase != null)
        {
            <p class="text-muted small mb-3">@Phase.SystemPhase.Description</p>
        }

        <div class="phase-stats mb-4">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted fw-bold">Tasks:</span>
                <span class="badge bg-info">@Phase.TaskCount</span>
            </div>
        </div>

        @if (Phase.Tasks != null && Phase.Tasks.Any())
        {
            <div class="tasks-preview bg-light p-2 rounded border-start border-4 border-primary">
                <small class="text-muted d-block mb-2"><strong>Recent Tasks:</strong></small>
                <ul class="list-unstyled small mb-0">
                    @foreach (var task in Phase.Tasks.Take(3))
                    {
                        <li class="mb-1 text-truncate">
                            <i class="bi bi-check-circle-fill text-success me-1"></i> @task.Description
                        </li>
                    }
                </ul>
                @if (Phase.Tasks.Count > 3)
                {
                    <small class="text-muted mt-1 d-block">+@(Phase.Tasks.Count - 3) more...</small>
                }
            </div>
        }
    </div>
</div>
<style>
    .phase-card {
        transition: all 0.3s ease;
        border: 2px solid #e0e0e0;
        cursor: pointer;
    }

        .phase-card:hover {
            border-color: #0d6efd;
            transform: translateY(-4px);
            box-shadow: 0 6px 20px rgba(13,110,253,0.2);
        }

</style>
